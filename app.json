{
  "expo": {
    "name": "Limkokwing Prospectus 2026",
    "slug": "limkokwing-prospectus",
    "description": " Limkokwing University Digital Prospectus App",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/1.png",
    "scheme": "limkokwingprospectus",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,

    "ios": {
      "bundleIdentifier": "com.limkokwing.prospectus",
      "supportsTablet": true,
      "infoPlist": {
        "UIStatusBarStyle": "UIStatusBarStyleDarkContent"
      }
    },

    "android": {
      "package": "com.limkokwing.prospectus",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/1.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": true
    },

    "web": {
      "output": "static",
      "favicon": "./assets/image/1.png"
    },

    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/1.png",
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],

    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },

    "extra": {
      "projectName": "Limkokwing Prospectus"
    }
  }
}